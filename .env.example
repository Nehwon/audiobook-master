# =========================
# Container runtime
# =========================
APP_IMAGE=ghcr.io/nehwon/audiobook-master:latest
APP_CONTAINER_NAME=audiobook-manager-pro
APP_USER=0:0
APP_RESTART_POLICY=unless-stopped
APP_HTTP_PORT=8080

# =========================
# Bind mounts
# =========================
SOURCE_VOLUME=./data/source
OUTPUT_VOLUME=./data/output
TMP_VOLUME=/tmp
LOGS_VOLUME=./logs
CONFIG_VOLUME=./core/config.py

# =========================
# App env vars
# =========================
FLASK_ENV=production
HOST=0.0.0.0
PORT=8080
APP_PORT=5001
OLLAMA_BASE_URL=http://ollama:11434
GUNICORN_WORKERS=1
GUNICORN_THREADS=8
GUNICORN_TIMEOUT=300
SOURCE_DIR=/app/data/source
OUTPUT_DIR=/app/data/output
TEMP_DIR=/tmp/audiobooks_web
LOG_LEVEL=INFO
MAX_WORKERS=32
CPU_THREADS=16
BATCH_THREADS=8

# =========================
# Healthcheck / resources
# =========================
APP_HEALTHCHECK_INTERVAL=30s
APP_HEALTHCHECK_TIMEOUT=10s
APP_HEALTHCHECK_RETRIES=3
APP_HEALTHCHECK_START_PERIOD=40s
APP_LIMIT_CPUS=16
APP_LIMIT_MEMORY=8G
APP_RESERVATION_CPUS=4
APP_RESERVATION_MEMORY=2G


# =========================
# Ollama
# =========================
OLLAMA_IMAGE=ollama/ollama:latest
OLLAMA_CONTAINER_NAME=audiobook-ollama
OLLAMA_RESTART_POLICY=unless-stopped
OLLAMA_PORT=11434
OLLAMA_DATA_VOLUME=ollama-data
OLLAMA_KEEP_ALIVE=30m
OLLAMA_HEALTHCHECK_INTERVAL=30s
OLLAMA_HEALTHCHECK_TIMEOUT=10s
OLLAMA_HEALTHCHECK_RETRIES=10
OLLAMA_HEALTHCHECK_START_PERIOD=30s
OLLAMA_VOLUME_DRIVER=local

# =========================
# Prometheus
# =========================
PROMETHEUS_IMAGE=prom/prometheus:latest
PROMETHEUS_CONTAINER_NAME=audiobook-prometheus
PROMETHEUS_RESTART_POLICY=unless-stopped
PROMETHEUS_PORT=9090
PROMETHEUS_CONFIG_VOLUME=./monitoring/prometheus.yml
PROMETHEUS_DATA_VOLUME=prometheus-data
PROMETHEUS_CONFIG_FILE=/etc/prometheus/prometheus.yml
PROMETHEUS_STORAGE_PATH=/prometheus
PROMETHEUS_CONSOLE_LIBRARIES=/etc/prometheus/console_libraries
PROMETHEUS_CONSOLE_TEMPLATES=/etc/prometheus/consoles
PROMETHEUS_RETENTION=200h
PROMETHEUS_PROFILE=monitoring
PROMETHEUS_VOLUME_DRIVER=local

# =========================
# Grafana
# =========================
GRAFANA_IMAGE=grafana/grafana:latest
GRAFANA_CONTAINER_NAME=audiobook-grafana
GRAFANA_RESTART_POLICY=unless-stopped
GRAFANA_PORT=3000
GRAFANA_DATA_VOLUME=grafana-data
GRAFANA_DASHBOARDS_VOLUME=./monitoring/grafana/dashboards
GRAFANA_DATASOURCES_VOLUME=./monitoring/grafana/datasources
GF_SECURITY_ADMIN_PASSWORD=admin123
GF_USERS_ALLOW_SIGN_UP=false
GRAFANA_PROFILE=monitoring
GRAFANA_VOLUME_DRIVER=local

# =========================
# Postgres
# =========================
POSTGRES_IMAGE=postgres:15-alpine
POSTGRES_CONTAINER_NAME=audiobook-postgres
POSTGRES_RESTART_POLICY=unless-stopped
POSTGRES_PORT=5432
POSTGRES_DATA_VOLUME=postgres-data
POSTGRES_INIT_VOLUME=./database/init.sql
POSTGRES_DB=audiobook_manager
POSTGRES_USER=audiobook
POSTGRES_PASSWORD=audiobook123
POSTGRES_INITDB_ARGS=--encoding=UTF-8 --lc-collate=C --lc-ctype=C
POSTGRES_PROFILE=database
POSTGRES_VOLUME_DRIVER=local

# =========================
# Redis
# =========================
REDIS_IMAGE=redis:7-alpine
REDIS_CONTAINER_NAME=audiobook-redis
REDIS_RESTART_POLICY=unless-stopped
REDIS_PORT=6379
REDIS_DATA_VOLUME=redis-data
REDIS_COMMAND=redis-server --appendonly yes --maxmemory 512mb --maxmemory-policy allkeys-lru
REDIS_PROFILE=cache
REDIS_VOLUME_DRIVER=local

# =========================
# Network
# =========================
NETWORK_DRIVER=bridge
NETWORK_SUBNET=172.20.0.0/16
